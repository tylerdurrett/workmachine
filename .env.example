# Work Machine — environment template.
# Copy to `.env` (gitignored) and fill in real values. The GitHub tracker
# adapter (issue #5) reads these to surface runs as review cards.

# Fine-grained PAT for the sandbox repo. Scope it to ONLY the
# WORKMACHINE_SANDBOX_REPO below, with: Issues = read & write, Metadata = read.
# Used to create the run-card issue, post the review card, and poll commands.
# This is a real secret — it stays in env in dev and production alike.
WORKMACHINE_GITHUB_TOKEN=

# Local-dev default for which repo run cards land on, as `owner/repo`. NOT part
# of the real interface: in production the operator picks the tracker per run via
# `run create --repo owner/name`; this is only the fallback so we don't retype
# the sandbox on every command while building and demoing the slice.
WORKMACHINE_SANDBOX_REPO=tylerdurrett/workmachine-sandbox
